{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "composite": true
  },
  "include": [
    "src/index.ts",
    "src/runtime/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
